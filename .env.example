# Copy to .env and fill in real values (do NOT commit secrets)
PORT=3000
APP_URL=https://your-cmis-app.onrender.com   # Where /app should redirect for now
SESSION_SECRET=replace-me-with-a-secure-secret
DATABASE_URL=postgres://user:pass@host:5432/dbname
GCS_BUCKET=
SENDGRID_API_KEY=
STRIPE_KEY=
NODE_ENV=development
# Secret used to verify HMAC-SHA256 signatures on incoming super-admin webhook requests.
# Must match the value configured in the super-admin service sending the webhooks.
# Generate with: openssl rand -hex 32
SUPER_ADMIN_WEBHOOK_SECRET=replace-me-with-a-secure-random-secret